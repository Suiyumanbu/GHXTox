{
  "seed": 42,
  "data": {
    "max_length": 128,
    "structure_mode": "cached",
    "structure_cache_dir": "data/structures"
  },
  "model": {
    "aa_embedding_dim": 32,
    "group_embedding_dim": 12,
    "hidden_dim": 128,
    "num_sequence_layers": 2,
    "num_egnn_layers": 3,
    "num_attention_heads": 4,
    "dropout": 0.22,
    "graph_mode": "hybrid",
    "spatial_top_k": 10,
    "rbf_bins": 16,
    "rbf_max_distance": 24.0,
    "fusion_gate": "learned_confidence",
    "ahp_initial_3d_weight": 0.35,
    "plddt_gate_center": 0.7,
    "plddt_gate_temperature": 0.12,
    "plddt_edge_min": 0.1,
    "plddt_edge_power": 1.5,
    "plm_embedding_dim": 1280,
    "structure_feature_dim": 16,
    "global_features": true,
    "chemical_site_branch": true,
    "chemical_site_type_dim": 8,
    "chemical_site_hidden_dim": 64,
    "chemical_site_layers": 2,
    "chemical_site_raw_rbf_bins": 16,
    "chemical_site_normalized_rbf_bins": 8,
    "chemical_site_max_distance": 16.0,
    "chemical_site_normalized_max_distance": 4.0,
    "chemical_site_dropout": 0.1,
    "chemical_site_use_raw_rbf": true,
    "chemical_site_use_normalized_rbf": true,
    "chemical_site_use_orientation": true,
    "chemical_site_use_interaction_types": true,
    "chemical_site_use_plddt": true,
    "chemical_site_use_hydrophobic_sites": true,
    "chemical_site_max_site_slots": 2,
    "chemical_site_exclude_same_residue_edges": false,
    "chemical_site_zero_init_residual": true
  },
  "train": {
    "epochs": 30,
    "batch_size": 32,
    "learning_rate": 0.0005,
    "weight_decay": 0.0001,
    "val_fraction": 0.15,
    "early_stop_patience": 8,
    "pos_weight": "auto",
    "coord_noise_std": 0.12,
    "coord_noise_plddt_scale": 2.0,
    "monitor": "mcc",
    "initial_checkpoint": "runs/plm_fusion_esm2_geometry_confidence/best_model.pt",
    "allowed_missing_prefixes": [
      "chemical_site_branch."
    ],
    "trainable_prefixes": [
      "chemical_site_branch."
    ]
  },
  "inference": {
    "default_threshold": 0.677819,
    "threshold_source": "five-fold group-aware OOF MCC optimization",
    "fallback_checkpoint": "runs/plm_fusion_esm2_geometry_confidence/best_model.pt",
    "fallback_threshold": 0.85
  },
  "experiment": {
    "name": "3d_v2_default_full_refit",
    "fixed_epochs": 8,
    "epoch_source": "median of five Pareto-selected best epochs: 8, 8, 14, 2, 4",
    "selection_data": "training-only CD-HIT 0.80 group folds",
    "external_sets_used_for_selection": false
  }
}