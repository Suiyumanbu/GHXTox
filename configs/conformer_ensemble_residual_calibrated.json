{
  "seed": 42,
  "data": {
    "max_length": 128,
    "structure_mode": "cached",
    "structure_cache_dir": "data/structures"
  },
  "model": {
    "aa_embedding_dim": 32,
    "group_embedding_dim": 12,
    "hidden_dim": 128,
    "num_sequence_layers": 2,
    "num_egnn_layers": 3,
    "num_attention_heads": 4,
    "dropout": 0.22,
    "graph_mode": "hybrid",
    "spatial_top_k": 10,
    "rbf_bins": 16,
    "rbf_max_distance": 24.0,
    "fusion_gate": "learned_confidence",
    "ahp_initial_3d_weight": 0.35,
    "plddt_gate_center": 0.7,
    "plddt_gate_temperature": 0.12,
    "plddt_edge_min": 0.1,
    "plddt_edge_power": 1.5,
    "plm_embedding_dim": 1280,
    "structure_feature_dim": 16,
    "global_features": true,
    "chemical_site_branch": true,
    "chemical_site_type_dim": 8,
    "chemical_site_hidden_dim": 64,
    "chemical_site_layers": 2,
    "chemical_site_raw_rbf_bins": 16,
    "chemical_site_normalized_rbf_bins": 8,
    "chemical_site_max_distance": 16.0,
    "chemical_site_normalized_max_distance": 4.0,
    "chemical_site_dropout": 0.1,
    "chemical_site_use_raw_rbf": true,
    "chemical_site_use_normalized_rbf": true,
    "chemical_site_use_orientation": true,
    "chemical_site_use_interaction_types": true,
    "chemical_site_use_plddt": true,
    "chemical_site_use_hydrophobic_sites": true,
    "chemical_site_max_site_slots": 2,
    "chemical_site_exclude_same_residue_edges": false,
    "chemical_site_zero_init_residual": true,
    "conformer_ensemble_branch": true,
    "conformer_ensemble_hidden_dim": 32,
    "conformer_ensemble_dropout": 0.25,
    "conformer_ensemble_initial_weight": 0.25
  },
  "train": {
    "epochs": 50,
    "batch_size": 32,
    "learning_rate": 0.001,
    "weight_decay": 0.0005,
    "val_fraction": 0.15,
    "early_stop_patience": 8,
    "pos_weight": "none",
    "coord_noise_std": 0.0,
    "monitor": "loss",
    "initial_checkpoint": "runs/chemical_site_ablation_include_same_residue_fold{fold}/best_model.pt",
    "allowed_missing_prefixes": [
      "conformer_residue_encoder.",
      "conformer_global_encoder.",
      "conformer_ensemble_branch.",
      "conformer_ensemble_logit"
    ],
    "trainable_prefixes": [
      "conformer_residue_encoder.",
      "conformer_global_encoder.",
      "conformer_ensemble_branch.",
      "conformer_ensemble_logit"
    ],
    "conformer_delta_l1": 0.005
  },
  "inference": {
    "default_checkpoint": "runs/3d_v2_conformer_ensemble_candidate/best_model.pt",
    "default_threshold": 0.677819,
    "threshold_source": "frozen original 3D-v2 group-aware OOF threshold; conformer full-OOF optimum 0.676449",
    "fallback_checkpoint": "runs/plm_fusion_esm2_geometry_confidence/best_model.pt",
    "fallback_threshold": 0.85,
    "conformer_missing_policy": "zero residual through hard conformer_available mask"
  },
  "experiment": {
    "name": "pepflow_conformer_ensemble_residual_calibrated",
    "change_from_first_pass": "avoid a second class-weight correction and select by held-out BCE",
    "scope": "single prespecified refinement after probability-shift diagnosis"
  }
}
