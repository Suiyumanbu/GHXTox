  "train": {"epochs": 30, "batch_size": 32, "learning_rate": 0.0005, "weight_decay": 0.0001, "val_fraction": 0.15, "early_stop_patience": 8, "pos_weight": "auto", "coord_noise_std": 0.12, "coord_noise_plddt_scale": 2.0, "monitor": "mcc"}
