# =========================
# 1. Python 缓存和运行文件
# =========================
__pycache__/
*.py[cod]
*$py.class

# =========================
# 2. 虚拟环境（最容易导致体积超标）
# =========================
venv/
env/
.env/
.venv/
Scripts/
Lib/

# Keep the project-level AutoDL launcher while still ignoring environment Scripts/.
!/scripts/
/scripts/*
!/scripts/generate_prott5_pooled_autodl.sh
!/scripts/generate_prott5_tokens_autodl.sh

# =========================
# 3. 深度学习模型权重
# =========================
*.pt
*.pth
*.h5
*.ckpt
*.safetensors

# =========================
# 4. 数据集和临时大文件
# =========================
*.csv
*.tsv
*.npy
*.npz
*.fasta
/data/*
!/data/pepflow_pilot/
/data/pepflow_pilot/*
!/data/pepflow_pilot/train_pilot_250.fasta
!/data/pepflow_pilot/train_pilot_250.csv
/dataset/
/temp/

# =========================
